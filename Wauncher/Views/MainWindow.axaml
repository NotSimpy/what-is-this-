<Window
    x:Class="Wauncher.Views.MainWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:svg="clr-namespace:Avalonia.Svg.Controls;assembly=Avalonia.Svg.Skia"
    xmlns:vm="using:Wauncher.ViewModels"
    xmlns:controls="using:Wauncher.Views.Controls"
    Title="ClassicCounter Wauncher"
    Width="1024"
    Height="528"
    MinWidth="1024"
    MinHeight="528"
    d:DesignHeight="528"
    d:DesignWidth="1024"
    x:DataType="vm:MainWindowViewModel"
    Icon="/Assets/Wauncher.ico"
    SystemDecorations="None"
    TransparencyLevelHint="AcrylicBlur"
    WindowStartupLocation="CenterScreen"
    Background="Transparent"
    mc:Ignorable="d">

    <Window.Transitions>
        <Transitions>
            <DoubleTransition Property="Height" Duration="0:0:0.22" Easing="CubicEaseOut" />
        </Transitions>
    </Window.Transitions>

    <Window.Styles>
        <!-- ════════════════════════════════════════════════
             MINIMIZE — fade to white on hover
             ════════════════════════════════════════════════ -->
        <Style Selector="Button.titleBtn">
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
            <!-- Custom template bypasses Avalonia's default hover override -->
            <Setter Property="Template">
                <ControlTemplate>
                    <Border
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="{TemplateBinding Background}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.titleBtn:pointerover">
            <Setter Property="Background" Value="#44FFFFFF" />
        </Style>
        <Style Selector="Button.titleBtn:pressed">
            <Setter Property="Background" Value="#22FFFFFF" />
        </Style>

        <!-- ════════════════════════════════════════════════
             CLOSE — straight to red, no grey flash
             ════════════════════════════════════════════════ -->
        <Style Selector="Button.closeBtn">
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="CornerRadius" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15" />
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="{TemplateBinding Background}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.closeBtn:pointerover">
            <Setter Property="Background" Value="#CCE53935" />
        </Style>
        <Style Selector="Button.closeBtn:pressed">
            <Setter Property="Background" Value="#FFB71C1C" />
        </Style>

        <!-- ════════════════════════════════════════════════
             ICON BUTTONS (Settings / Info) — frosted circle
             Custom template so hover is always respected
             ════════════════════════════════════════════════ -->
        <Style Selector="Button.iconBtn">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="{DynamicResource AppIconBtnBg}" />
            <Setter Property="Effect">
                <DropShadowEffect BlurRadius="8" Color="Black" OffsetX="0" OffsetY="2" Opacity="0.3" />
            </Setter>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.18" />
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{DynamicResource AppIconBtnBorder}"
                        BorderThickness="1"
                        CornerRadius="{TemplateBinding CornerRadius}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.iconBtn:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppIconBtnHover}" />
        </Style>
        <Style Selector="Button.iconBtn:pressed">
            <Setter Property="Background" Value="{DynamicResource AppIconBtnPressed}" />
        </Style>
        <Style Selector="Button.serverSelectorBtn:disabled">
            <Setter Property="Background" Value="#2A2A2A" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style Selector="Button.serverSelectorBtn:disabled Image">
            <Setter Property="Opacity" Value="0.5" />
        </Style>

        <!-- ════════════════════════════════════════════════
             LAUNCH BUTTON — green → brighter green
             ════════════════════════════════════════════════ -->
        <Style Selector="Button.launchBtn">
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="#4CAF50" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border
                        x:Name="PART_Border"
                        Background="{TemplateBinding Background}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        Padding="{TemplateBinding Padding}">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition Property="Background" Duration="0:0:0.18" />
                            </Transitions>
                        </Border.Transitions>
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.launchBtn:pointerover /template/ Border#PART_Border">
            <Setter Property="Background" Value="#66000000" />
        </Style>
        <Style Selector="Button.launchBtn:pressed /template/ Border#PART_Border">
            <Setter Property="Background" Value="#44000000" />
        </Style>
        <!-- Yellow when updating -->
        <Style Selector="Button.launchBtn.updating">
            <Setter Property="Background" Value="#FFC107" />
        </Style>
        <Style Selector="Button.launchBtn.installPending">
            <Setter Property="Background" Value="#2196F3" />
        </Style>
        <Style Selector="Button.launchBtn.updatePending">
            <Setter Property="Background" Value="#FFC107" />
        </Style>
        <Style Selector="Border.launchGlow.installPending">
            <Setter Property="BoxShadow" Value="0 0 18 2 #552196F3" />
        </Style>
        <Style Selector="Border.launchGlow.updatePending">
            <Setter Property="BoxShadow" Value="0 0 18 2 #55FFC107" />
        </Style>

        <!-- ════════════════════════════════════════════════
             SERVER SELECTOR TRIGGER — invisible button chrome
             ════════════════════════════════════════════════ -->
        <Style Selector="Button.serverTrigger">
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter
                        Padding="{TemplateBinding Padding}"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                        Content="{TemplateBinding Content}" />
                </ControlTemplate>
            </Setter>
        </Style>

        <!-- ════════════════════════════════════════════════
             SERVER LIST ROWS — hover highlight
             ════════════════════════════════════════════════ -->
        <Style Selector="Button.serverBtn">
            <Setter Property="Padding" Value="10,9" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12" />
                </Transitions>
            </Setter>
            <Setter Property="Template">
                <ControlTemplate>
                    <Border
                        Background="{TemplateBinding Background}"
                        CornerRadius="5"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.serverBtn:pointerover">
            <Setter Property="Background" Value="{DynamicResource AppServerHover}" />
        </Style>
        <Style Selector="Button.serverBtn:pressed">
            <Setter Property="Background" Value="{DynamicResource AppServerPressed}" />
        </Style>
        <Style Selector="Button.friendMenuBtn">
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Width" Value="18" />
            <Setter Property="Height" Value="18" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <ContentPresenter
                        Padding="{TemplateBinding Padding}"
                        HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                        VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                        Content="{TemplateBinding Content}" />
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.friendMenuBtn:pointerover">
            <Setter Property="Background" Value="#22FFFFFF" />
        </Style>
        <Style Selector="Button.friendRowBtn">
            <Setter Property="Padding" Value="0" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="MinHeight" Value="50" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border
                        Background="{TemplateBinding Background}"
                        CornerRadius="6"
                        MinHeight="{TemplateBinding MinHeight}"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="Center"
                            Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.friendRowBtn:pointerover">
            <Setter Property="Background" Value="#14FFFFFF" />
        </Style>
        <Style Selector="MenuItem.compactFlyoutItem">
            <Setter Property="FontSize" Value="12.5" />
            <Setter Property="Padding" Value="9,5" />
            <Setter Property="MinHeight" Value="0" />
        </Style>

        <!-- Selected label default (no server) -->
        <Style Selector="TextBlock.selectedlabel">
            <Setter Property="Foreground" Value="{DynamicResource AppMutedText}" />
        </Style>
        <!-- Server not selected: red + slow breathing opacity -->
        <Style Selector="TextBlock.selectedlabel.noserver">
            <Setter Property="Foreground" Value="#F44336" />
            <Style.Animations>
                <Animation Duration="0:0:2.5" IterationCount="Infinite" PlaybackDirection="Alternate" Easing="SineEaseInOut">
                    <KeyFrame Cue="0%">
                        <Setter Property="Opacity" Value="1.0" />
                    </KeyFrame>
                    <KeyFrame Cue="100%">
                        <Setter Property="Opacity" Value="0.3" />
                    </KeyFrame>
                </Animation>
            </Style.Animations>
        </Style>
        <!-- Server selected: green -->
        <Style Selector="TextBlock.selectedlabel.serverselected">
            <Setter Property="Foreground" Value="#4CAF50" />
        </Style>

        <!-- ════════════════════════════════════════════════
             TAB BUTTONS — FRIENDS / PATCH NOTES switcher
             ════════════════════════════════════════════════ -->
        <Style Selector="Button.tabBtn">
            <Setter Property="Padding" Value="0,10" />
            <Setter Property="BorderThickness" Value="0,0,0,2" />
            <Setter Property="BorderBrush" Value="Transparent" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="FontSize" Value="10" />
            <Setter Property="FontWeight" Value="Bold" />
            <Setter Property="Foreground" Value="{DynamicResource AppMutedText}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <ControlTemplate>
                    <Border
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        Padding="{TemplateBinding Padding}">
                        <ContentPresenter
                            HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                            VerticalAlignment="{TemplateBinding VerticalContentAlignment}"
                            Content="{TemplateBinding Content}" />
                    </Border>
                </ControlTemplate>
            </Setter>
        </Style>
        <Style Selector="Button.tabBtn.tabActive">
            <Setter Property="Foreground" Value="{DynamicResource AppPrimaryText}" />
            <Setter Property="BorderBrush" Value="#4CAF50" />
        </Style>
        <Style Selector="Button.tabBtn:pointerover">
            <Setter Property="Background" Value="#11FFFFFF" />
        </Style>
    </Window.Styles>

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid Background="#3A3A3A">
        <!-- ── Title bar ── -->
        <Grid
            x:Name="TitleBar"
            Height="36"
            VerticalAlignment="Top"
            Background="{DynamicResource AppTitleBarBrush}"
            PointerPressed="TitleBar_PointerPressed">
            <Image
            HorizontalAlignment="Center"
            VerticalAlignment="Center"
            Height="22"
            Source="avares://Wauncher/Assets/logo.png">
            <Image.Effect>
                <DropShadowEffect
                    BlurRadius="8"
                    Color="Black"
                    OffsetX="0"
                    OffsetY="1"
                    Opacity="0.8" />
            </Image.Effect>
        </Image>
            <StackPanel
                HorizontalAlignment="Right"
                VerticalAlignment="Stretch"
                Orientation="Horizontal"
                Spacing="0">
                <Button
                    x:Name="MinimizeButton"
                    Classes="titleBtn"
                    Width="46"
                    Height="36"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="MinimizeButton_Click">
                    <Path
                        Width="10"
                        Height="2"
                        Data="M0,1 L10,1"
                        Stroke="White"
                        StrokeThickness="1.5" />
                </Button>
                <Button
                    x:Name="CloseButton"
                    Classes="closeBtn"
                    Width="46"
                    Height="36"
                    HorizontalContentAlignment="Center"
                    VerticalContentAlignment="Center"
                    Click="CloseButton_Click">
                    <Path
                        Width="10"
                        Height="10"
                        Data="M0,0 L10,10 M10,0 L0,10"
                        Stroke="White"
                        StrokeThickness="1.5" />
                </Button>
            </StackPanel>
        </Grid>

        <!-- ── Main content: left column + right panel ── -->
        <Grid Margin="0,38,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="300" />
            </Grid.ColumnDefinitions>

            <!-- ── LEFT COLUMN: carousel + bottom bar ── -->
            <Grid Grid.Column="0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- ── CAROUSEL ── -->
                <Border Grid.Row="0" Margin="0" Background="#000000" BorderThickness="0" ClipToBounds="True">
                    <Grid x:Name="CarouselContainer">
                        <Border
                            x:Name="CarouselOfflinePanel"
                            IsVisible="False"
                            Background="#66000000">
                            <StackPanel
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Spacing="8">
                                <TextBlock
                                    x:Name="CarouselOfflineTitle"
                                    FontSize="18"
                                    FontWeight="Bold"
                                    Foreground="{DynamicResource AppPrimaryText}"
                                    HorizontalAlignment="Center"
                                    Text="No internet connection" />
                                <TextBlock
                                    x:Name="CarouselOfflineSubText"
                                    FontSize="12"
                                    Foreground="{DynamicResource AppMutedText}"
                                    HorizontalAlignment="Center"
                                    Text="Connect to Wi-Fi or Ethernet to load the carousel." />
                            </StackPanel>
                        </Border>
                    </Grid>
                </Border>

                <!-- Server dropdown overlay -->
                <controls:ServerListControl 
                    x:Name="ServerListControl"
                    Grid.Row="0" />

                <!-- Update bar -->
                <controls:UpdateBarControl 
                    x:Name="UpdateBarControl"
                    Grid.Row="1" />
            </Grid>

            <!-- ── VERTICAL DIVIDER ── -->
            <Rectangle Grid.Column="1" Width="1" Fill="{DynamicResource AppDivider}" />

            <!-- ── RIGHT PANEL: FRIENDS / PATCH NOTES tabs ── -->
            <Grid Grid.Column="2" Background="{DynamicResource AppRightPanelBg}" ClipToBounds="True">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="1" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <!-- Tab header buttons -->
                <Grid Grid.Row="0" ColumnDefinitions="*,*">
                    <Button
                        Grid.Column="0"
                        Classes="tabBtn"
                        Classes.tabActive="{Binding IsFriendsTabActive}"
                        Content="FRIENDS"
                        Command="{Binding SwitchToFriendsTabCommand}" />
                    <Button
                        Grid.Column="1"
                        Classes="tabBtn"
                        Classes.tabActive="{Binding IsPatchNotesTabActive}"
                        Content="PATCH NOTES"
                        Command="{Binding SwitchToPatchNotesTabCommand}" />
                </Grid>

                <!-- Tab divider -->
                <Rectangle Grid.Row="1" Fill="{DynamicResource AppDivider}" />

                <!-- ── FRIENDS TAB ── -->
                <controls:FriendsListControl 
                    x:Name="FriendsListControl"
                    Grid.Row="2" 
                    IsVisible="{Binding IsFriendsTabActive}" />

                <!-- ── PATCH NOTES TAB ── -->
                <controls:PatchNotesControl 
                    x:Name="PatchNotesControl"
                    Grid.Row="2" 
                    IsVisible="{Binding IsPatchNotesTabActive}" />
            </Grid>
        </Grid>
    </Grid>
</Window>
